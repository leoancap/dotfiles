*background: #1d2021
*foreground: #d4be98
*cursorColor: #add8e6

! Black + DarkGrey
*color0:  #282828
*color8:  #928374
! DarkRed + Red
*color1:  #ea6962
*color9:  #ea6962
! DarkGreen + Green
*color2:  #a9b665
*color10: #a9b665
! DarkYellow + Yellow
*color3:  #e78a4e
*color11: #e78a4e
! DarkBlue + Blue
*color4:  #7daea3
*color12: #7daea3
! DarkMagenta + Magenta
*color5:  #d3869b
*color13: #d3869b
! DarkCyan + Cyan
*color6:  #89b482
*color14: #89b482
! LightGrey + White
*color7:  #d4be98
*color15: #d4be98


UXTerm*termName:               xterm-256color
UXTerm*vt100.locale:           true
UXTerm*vt100.metaSendsEscape:  true
UXTerm*vt100.backarrowKey:     false
UXTerm*ttyModes:               erase ^?
UXTerm*vt100.saveLines:        4096
UXTerm*vt100.geometry:         100x32
UXTerm*vt100.translations:     #override \n\
                               Ctrl <Key> minus: smaller-vt-font() \n\
                               Ctrl <Key> plus: larger-vt-font()
UXTerm*vt100.faceName:         xos4 Terminess Powerline:size=16:antialias=true
UXTerm*vt100.boldFont:         xos4 Terminess Powerline:bold:size=16:antialias=true
UXTerm*vt100.allowTitleOps:    true
UXTerm*border:                 off
UXTerm*borderWidth:            0
UXTerm*Thickness:              0
UXTerm*loginShell:             true
UXTerm*multiScroll:            on
UXTerm*background:             #002B36
